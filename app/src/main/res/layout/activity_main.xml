<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".MainActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Gradient Premium Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/header_gradient"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="36dp"
                android:paddingEnd="24dp"
                android:paddingBottom="36dp">

                <TextView
                    android:id="@+id/app_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Qué Comemos"
                    android:textColor="@color/white"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/app_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Tu Dieta Personal - Samuel García"
                    android:textColor="#E0F2F1"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/selected_day_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Día 1"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_shopping_list"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="🛒 Lista de la Compra Semanal"
                    android:textColor="@color/white"
                    app:backgroundTint="#33FFFFFF"
                    app:iconTint="@color/white" />
            </LinearLayout>

            <!-- Horizontal Day Selector -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:scrollbars="none"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <LinearLayout
                    android:id="@+id/days_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Day 1 Button -->
                    <TextView
                        android:id="@+id/day_1_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/day_pill_selected"
                        android:paddingStart="18dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="10dp"
                        android:text="Día 1"
                        android:textColor="@color/day_selected_text"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- Day 2 Button -->
                    <TextView
                        android:id="@+id/day_2_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/day_pill_unselected"
                        android:paddingStart="18dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="10dp"
                        android:text="Día 2"
                        android:textColor="@color/day_unselected_text"
                        android:textSize="14sp" />

                    <!-- Day 3 Button -->
                    <TextView
                        android:id="@+id/day_3_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/day_pill_unselected"
                        android:paddingStart="18dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="10dp"
                        android:text="Día 3"
                        android:textColor="@color/day_unselected_text"
                        android:textSize="14sp" />

                    <!-- Day 4 Button -->
                    <TextView
                        android:id="@+id/day_4_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/day_pill_unselected"
                        android:paddingStart="18dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="10dp"
                        android:text="Día 4"
                        android:textColor="@color/day_unselected_text"
                        android:textSize="14sp" />

                    <!-- Day 5 Button -->
                    <TextView
                        android:id="@+id/day_5_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/day_pill_unselected"
                        android:paddingStart="18dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="10dp"
                        android:text="Día 5"
                        android:textColor="@color/day_unselected_text"
                        android:textSize="14sp" />

                    <!-- Day 6 Button -->
                    <TextView
                        android:id="@+id/day_6_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/day_pill_unselected"
                        android:paddingStart="18dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="10dp"
                        android:text="Día 6"
                        android:textColor="@color/day_unselected_text"
                        android:textSize="14sp" />

                    <!-- Day 7 Button -->
                    <TextView
                        android:id="@+id/day_7_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/day_pill_unselected"
                        android:paddingStart="18dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="10dp"
                        android:text="Día 7"
                        android:textColor="@color/day_unselected_text"
                        android:textSize="14sp" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Meals List Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 1. Desayuno Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_desayuno"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/card_dark"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:id="@+id/desayuno_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🍳 Desayuno"
                                android:textColor="@color/white"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/desayuno_kcal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:background="@color/day_unselected_bg"
                                android:paddingStart="8dp"
                                android:paddingTop="2dp"
                                android:paddingEnd="8dp"
                                android:paddingBottom="2dp"
                                android:text="653 kcal"
                                android:textColor="@color/teal_accent"
                                android:textSize="12sp"
                                android:textStyle="bold"/>
                        </RelativeLayout>

                        <TextView
                            android:id="@+id/desayuno_dishes"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Cereales rellenos de Leche..."
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Toca para ver ingredientes y preparación"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:textStyle="italic" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 2. Media Mañana Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_media_manana"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/card_dark"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:id="@+id/media_manana_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🍎 Media mañana"
                                android:textColor="@color/white"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/media_manana_kcal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:background="@color/day_unselected_bg"
                                android:paddingStart="8dp"
                                android:paddingTop="2dp"
                                android:paddingEnd="8dp"
                                android:paddingBottom="2dp"
                                android:text="543 kcal"
                                android:textColor="@color/teal_accent"
                                android:textSize="12sp"
                                android:textStyle="bold"/>
                        </RelativeLayout>

                        <TextView
                            android:id="@+id/media_manana_dishes"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Bocadillo de Jamón Serrano..."
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Toca para ver ingredientes y preparación"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:textStyle="italic" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 3. Almuerzo Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_almuerzo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/card_dark"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:id="@+id/almuerzo_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🍲 Almuerzo"
                                android:textColor="@color/white"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/almuerzo_kcal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:background="@color/day_unselected_bg"
                                android:paddingStart="8dp"
                                android:paddingTop="2dp"
                                android:paddingEnd="8dp"
                                android:paddingBottom="2dp"
                                android:text="888 kcal"
                                android:textColor="@color/teal_accent"
                                android:textSize="12sp"
                                android:textStyle="bold"/>
                        </RelativeLayout>

                        <TextView
                            android:id="@+id/almuerzo_dishes"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Pasta a la Boloñesa..."
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Toca para ver ingredientes y preparación"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:textStyle="italic" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 4. Merienda Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_merienda"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/card_dark"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:id="@+id/merienda_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🥛 Merienda"
                                android:textColor="@color/white"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/merienda_kcal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:background="@color/day_unselected_bg"
                                android:paddingStart="8dp"
                                android:paddingTop="2dp"
                                android:paddingEnd="8dp"
                                android:paddingBottom="2dp"
                                android:text="316 kcal"
                                android:textColor="@color/teal_accent"
                                android:textSize="12sp"
                                android:textStyle="bold"/>
                        </RelativeLayout>

                        <TextView
                            android:id="@+id/merienda_dishes"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Cereales rellenos..."
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Toca para ver ingredientes y preparación"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:textStyle="italic" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 5. Cena Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_cena"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/card_dark"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:id="@+id/cena_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🥗 Cena"
                                android:textColor="@color/white"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/cena_kcal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:background="@color/day_unselected_bg"
                                android:paddingStart="8dp"
                                android:paddingTop="2dp"
                                android:paddingEnd="8dp"
                                android:paddingBottom="2dp"
                                android:text="444 kcal"
                                android:textColor="@color/teal_accent"
                                android:textSize="12sp"
                                android:textStyle="bold"/>
                        </RelativeLayout>

                        <TextView
                            android:id="@+id/cena_dishes"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Crema de zanahorias..."
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Toca para ver ingredientes y preparación"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:textStyle="italic" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>