<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="16dp">

    <!-- Dish Title -->
    <TextView
        android:id="@+id/dish_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pasta a la Boloñesa"
        android:textColor="@color/teal_accent"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- Ingredients Header -->
    <TextView
        android:id="@+id/ingredients_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📝 Ingredientes (toca para marcar)"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp"/>

    <!-- Ingredients Checkbox List Container -->
    <LinearLayout
        android:id="@+id/ingredients_checkbox_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="12dp">
        <!-- Checkboxes will be programmatically added here -->
    </LinearLayout>

    <!-- Elaboration Section -->
    <LinearLayout
        android:id="@+id/elaboration_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🍳 Preparación"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/dish_elaboration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="3sp"
            android:text="Instrucciones detalladas de preparación..."
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
    </LinearLayout>

</LinearLayout>
