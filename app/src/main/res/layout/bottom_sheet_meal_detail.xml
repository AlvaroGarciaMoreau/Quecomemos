<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/card_dark"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Drag Handle -->
    <View
        android:layout_width="48dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="#424242" />

    <!-- Title and Kcal Summary Row -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/detail_meal_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🍲 Almuerzo"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/detail_meal_kcal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@color/day_unselected_bg"
            android:paddingStart="10dp"
            android:paddingTop="4dp"
            android:paddingEnd="10dp"
            android:paddingBottom="4dp"
            android:text="888 kcal"
            android:textColor="@color/teal_accent"
            android:textSize="14sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Macros Grid -->
    <LinearLayout
        android:id="@+id/macros_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:orientation="horizontal"
        android:weightSum="3">

        <!-- Protein Macro -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/day_unselected_bg"
            android:padding="8dp"
            android:layout_marginEnd="6dp"
            android:backgroundTint="#1A64B5F6">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Proteínas"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/detail_macro_protein"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="57g"
                android:textColor="@color/macro_protein"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Carbs Macro -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/day_unselected_bg"
            android:padding="8dp"
            android:layout_marginEnd="6dp"
            android:backgroundTint="#1A81C784">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hidratos"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/detail_macro_carbs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="90g"
                android:textColor="@color/macro_carbs"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Fat Macro -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/day_unselected_bg"
            android:padding="8dp"
            android:backgroundTint="#1ABA68C8">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Grasas"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/detail_macro_fat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="27g"
                android:textColor="@color/macro_fat"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Scrollable content for details -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="420dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Dishes Details Container -->
            <LinearLayout
                android:id="@+id/dishes_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Dynamic dishes with checklist and instructions will be inflated here in Kotlin -->

            </LinearLayout>

            <!-- Divider -->
            <View
                android:id="@+id/alternatives_divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="#424242" />

            <!-- Alternatives Header -->
            <TextView
                android:id="@+id/alternatives_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔄 Recetas/Menús Alternativos"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <!-- Alternatives List -->
            <TextView
                android:id="@+id/detail_alternatives_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="4sp"
                android:text="• Paella de pollo\n• Habas tiernas con acelgas"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
